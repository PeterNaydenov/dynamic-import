{
  "name": "@peter.naydenov/dynamic-import",
  "description": "Dynamic import function for ES modules that works with Vite bundler",
  "version": "1.1.0",
  "license": "MIT",
  "author": {
    "name": "Peter Naydenov"
  },
  "main": "./src/main.js",
  "types": "./dist/dynamic-import.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/dynamic-import.d.ts",
      "import": "./dist/dynamic-import.esm.mjs",
      "require": "./dist/dynamic-import.cjs",
      "default": "./dist/dynamic-import.umd.js"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*",
    "./src/*": "./src/*"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc",
    "types": "tsc",
    "test": "vitest",
    "cover": "vitest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PeterNaydenov/dynamic-import.git"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "import",
    "dynamic import",
    "vite",
    "ES Modules"
  ]
}
